datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Document {
  id          String   @id @default(uuid())
  code        String   @unique
  date        DateTime @default(now())
  partner     String
  description String
  amount      Float
  status      String   // PENDING, COMPLETED, DRAFT
}

model MasterDataItem {
  id          String   @id @default(uuid())
  type        String
  code        String
  name        String
  group       String?
  branch      String?
  taxCode     String?
  contactName String?
  phone       String?
  email       String?
  accountNo   String?
  status      String   @default("ACTIVE")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, code])
  @@index([type])
  @@index([status])
}

model Deposit {
  id              String           @id @default(uuid())
  code            String           @unique
  receivedDate    DateTime         @default(now())
  partnerCode     String
  partnerName     String
  branchCode      String
  moneySourceCode String
  amount          Float
  remainingAmount Float
  purpose         String
  status          String           @default("HOLDING")
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  histories       DepositHistory[]

  @@index([status])
  @@index([partnerCode])
  @@index([branchCode])
}

model DepositHistory {
  id        String   @id @default(uuid())
  depositId String
  action    String
  amount    Float?
  note      String?
  actor     String?
  createdAt DateTime @default(now())
  deposit   Deposit  @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@index([depositId])
}

model OpeningBalance {
  id              String   @id @default(uuid())
  period          String
  branchCode      String
  balanceType     String
  objectCode      String?
  objectName      String?
  moneySourceCode String?
  amount          Float
  note            String?
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([period])
  @@index([balanceType])
  @@index([status])
}

model ImportBatch {
  id             String   @id @default(uuid())
  importType     String
  templateCode   String
  fileName       String
  uploadedBy     String?
  status         String   @default("PREVIEW")
  totalRows      Int      @default(0)
  validRows      Int      @default(0)
  errorRows      Int      @default(0)
  mappingJson    String?
  errorJson      String?
  committedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bankTransactions BankStatementTransaction[]
  revenueRows      RevenueImportRow[]

  @@index([importType])
  @@index([status])
  @@index([createdAt])
}

model BankStatementTransaction {
  id              String   @id @default(uuid())
  importBatchId   String
  transactionDate DateTime
  bankAccount     String
  transactionCode String
  description     String
  debitAmount     Float    @default(0)
  creditAmount    Float    @default(0)
  balanceAfter    Float?
  branchCode      String?
  partnerHint     String?
  reconcileStatus String   @default("UNMATCHED")
  createdAt       DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([bankAccount, transactionCode])
  @@index([transactionDate])
  @@index([bankAccount])
  @@index([reconcileStatus])
}

model RevenueImportRow {
  id             String   @id @default(uuid())
  importBatchId  String
  saleDate       DateTime
  branchCode     String
  channel        String?
  revenueSource  String
  paymentMethod  String
  orderCount     Int?
  grossAmount    Float
  discountAmount Float    @default(0)
  vatAmount      Float    @default(0)
  feeAmount      Float    @default(0)
  netAmount      Float
  externalRef    String
  createdAt      DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([branchCode, saleDate, externalRef])
  @@index([saleDate])
  @@index([branchCode])
  @@index([paymentMethod])
}
