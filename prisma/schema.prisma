datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/@prisma/custom-client"
  engineType = "library"
}

model Document {
  id          String   @id @default(uuid())
  code        String   @unique
  date        DateTime @default(now())
  partner     String
  description String
  amount      Float
  status      String // PENDING, COMPLETED, DRAFT
}

model MasterDataItem {
  id           String   @id @default(uuid())
  type         String
  code         String
  name         String
  group        String?
  partnerType  String?
  partnerGroup String?
  branch       String?
  taxCode      String?
  contactName  String?
  phone        String?
  email        String?
  accountNo    String?
  status       String   @default("ACTIVE")
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([type, code])
  @@index([type])
  @@index([status])
  @@index([partnerType])
  @@index([partnerGroup])
}

model Deposit {
  id              String           @id @default(uuid())
  code            String           @unique
  receivedDate    DateTime         @default(now())
  partnerCode     String
  partnerName     String
  branchCode      String
  moneySourceCode String
  amount          Float
  remainingAmount Float
  purpose         String
  status          String           @default("HOLDING")
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  histories       DepositHistory[]

  @@index([status])
  @@index([partnerCode])
  @@index([branchCode])
}

model DepositHistory {
  id            String            @id @default(uuid())
  depositId     String
  voucherId     String?
  action        String
  amount        Float?
  actionDate    DateTime?
  treatmentNote String?
  note          String?
  actor         String?
  createdAt     DateTime          @default(now())
  deposit       Deposit           @relation(fields: [depositId], references: [id], onDelete: Cascade)
  voucher       FinancialVoucher? @relation(fields: [voucherId], references: [id], onDelete: SetNull)

  @@unique([voucherId, action])
  @@index([depositId])
  @@index([voucherId])
}

model OpeningBalance {
  id                    String   @id @default(uuid())
  period                String
  branchCode            String
  balanceType           String
  objectCode            String?
  objectName            String?
  moneySourceCode       String?
  warehouseCode         String?
  departmentCode        String?
  quantity              Float?
  unitCost              Float?
  allocationMonths      Int?
  allocationStartPeriod String?
  amount                Float
  note                  String?
  status                String   @default("DRAFT")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([period])
  @@index([branchCode])
  @@index([balanceType])
  @@index([status])
}

model ImportBatch {
  id           String    @id @default(uuid())
  importType   String
  templateCode String
  fileName     String
  branchCode   String?
  fileChecksum String?
  uploadedBy   String?
  status       String    @default("PREVIEW")
  totalRows    Int       @default(0)
  validRows    Int       @default(0)
  errorRows    Int       @default(0)
  mappingJson  String?
  errorJson    String?
  committedAt  DateTime?
  rolledBackAt DateTime?
  rolledBackBy String?
  rollbackNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bankTransactions      BankStatementTransaction[]
  revenueRows           RevenueImportRow[]
  payrollRows           PayrollImportRow[]
  importRows            ImportRow[]
  vouchers              FinancialVoucher[]
  moneyTransfers        MoneyTransfer[]
  debtRecords           DebtRecord[]
  inventoryTransactions InventoryTransaction[]

  @@index([importType])
  @@index([status])
  @@index([createdAt])
  @@index([fileChecksum])
}

model ImportRow {
  id              String   @id @default(uuid())
  importBatchId   String
  sheetName       String
  sourceRowNumber Int
  rawJson         String
  normalizedJson  String
  errorJson       String?
  rowFingerprint  String
  targetType      String?
  targetId        String?
  createdAt       DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([importBatchId, sheetName, sourceRowNumber])
  @@index([rowFingerprint])
  @@index([targetType, targetId])
}

model BankStatementTransaction {
  id              String   @id @default(uuid())
  importBatchId   String
  transactionDate DateTime
  bankAccount     String
  transactionCode String
  description     String
  debitAmount     Float    @default(0)
  creditAmount    Float    @default(0)
  balanceAfter    Float?
  branchCode      String?
  partnerHint     String?
  reconcileStatus String   @default("UNMATCHED")
  createdAt       DateTime @default(now())

  importBatch ImportBatch           @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  matches     ReconciliationMatch[]

  @@unique([bankAccount, transactionCode])
  @@index([transactionDate])
  @@index([bankAccount])
  @@index([reconcileStatus])
}

model RevenueImportRow {
  id              String   @id @default(uuid())
  importBatchId   String
  saleDate        DateTime
  branchCode      String
  channel         String?
  revenueSource   String
  paymentMethod   String
  orderCount      Int?
  grossAmount     Float
  discountAmount  Float    @default(0)
  vatAmount       Float    @default(0)
  feeAmount       Float    @default(0)
  netAmount       Float
  externalRef     String
  productCode     String?
  productQuantity Float?
  inventoryStatus String?
  createdAt       DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([branchCode, saleDate, externalRef])
  @@index([saleDate])
  @@index([branchCode])
  @@index([paymentMethod])
  @@index([productCode])
  @@index([inventoryStatus])
}

model FinancialVoucher {
  id                      String   @id @default(uuid())
  importBatchId           String?
  code                    String   @unique
  sourceDocumentCode      String?
  voucherType             String
  voucherDate             DateTime @default(now())
  partnerCode             String?
  partnerName             String
  branchCode              String
  sourceScope             String   @default("EXTERNAL")
  moneySourceCode         String
  categoryCode            String?
  externalRef             String?
  counterpartyAccountNo   String?
  counterpartyAccountName String?
  depositAction           String?
  depositCode             String?
  debtAction              String?
  debtReference           String?
  allocationMonths        Int?
  allocationStartPeriod   String?
  amount                  Float
  description             String
  status                  String   @default("DRAFT")
  createdBy               String?
  approvedBy              String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  importBatch      ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  depositHistories DepositHistory[]
  debtSettlement   DebtSettlement?

  @@index([voucherType])
  @@index([voucherDate])
  @@index([partnerCode])
  @@index([status])
  @@index([importBatchId])
  @@index([branchCode, voucherType, externalRef])
}

model DebtRecord {
  id                    String    @id @default(uuid())
  importBatchId         String?
  code                  String    @unique
  debtType              String
  partnerGroup          String    @default("EXTERNAL")
  partnerCode           String
  partnerName           String
  branchCode            String
  documentDate          DateTime
  dueDate               DateTime?
  categoryCode          String?
  originalAmount        Float
  outstandingAmount     Float
  allocationMonths      Int?
  allocationStartPeriod String?
  description           String
  sourceType            String    @default("IMPORT")
  sourceId              String?
  status                String    @default("OPEN")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  importBatch ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  settlements DebtSettlement[]

  @@index([branchCode])
  @@index([partnerCode])
  @@index([debtType, status])
  @@index([importBatchId])
}

model DebtSettlement {
  id             String   @id @default(uuid())
  debtId         String
  voucherId      String   @unique
  settlementDate DateTime
  amount         Float
  createdBy      String?
  createdAt      DateTime @default(now())

  debt    DebtRecord       @relation(fields: [debtId], references: [id], onDelete: Cascade)
  voucher FinancialVoucher @relation(fields: [voucherId], references: [id], onDelete: Restrict)

  @@index([debtId])
  @@index([settlementDate])
}

model AssetRecord {
  id                      String              @id @default(uuid())
  code                    String              @unique
  name                    String
  branchCode              String
  departmentCode          String?
  assetGroup              String
  imageUrl                String?
  location                String?
  warehouseCode           String?
  quantity                Float               @default(1)
  purchaseDate            DateTime
  originalCost            Float
  currentValue            Float
  accumulatedDepreciation Float               @default(0)
  usefulLifeMonths        Int?
  depreciationStartDate   DateTime?
  residualValue           Float               @default(0)
  supplierCode            String?
  supplierName            String?
  sourcePurchaseOrderId   String?
  sourceReceiptId         String?
  disposalDate            DateTime?
  disposalStatus          String?
  disposalAmount          Float?              @default(0)
  disposalNote            String?
  status                  String              @default("IN_USE")
  note                    String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  depreciations           AssetDepreciation[]
  maintenances            AssetMaintenance[]
  damageReports           AssetDamageReport[]

  @@index([branchCode])
  @@index([warehouseCode])
  @@index([departmentCode])
  @@index([assetGroup])
  @@index([status])
  @@index([sourcePurchaseOrderId])
}

model ReconciliationMatch {
  id                String    @id @default(uuid())
  bankTransactionId String
  targetType        String
  targetId          String
  targetCode        String
  targetDate        DateTime?
  targetAmount      Float
  matchedAmount     Float
  status            String    @default("MATCHED")
  note              String?
  matchedBy         String?
  createdAt         DateTime  @default(now())

  bankTransaction BankStatementTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)

  @@unique([bankTransactionId, targetType, targetId])
  @@index([targetType])
  @@index([status])
  @@index([createdAt])
}

model InventoryItem {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  itemType      String
  unit          String
  category      String?
  requiresImage Boolean  @default(false)
  minStock      Float    @default(0)
  status        String   @default("ACTIVE")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  balances         InventoryBalance[]
  unitConversions  ItemUnitConversion[]
  transactionLines InventoryTransactionLine[]
  recipeLines      RecipeLine[]
  stocktakeLines   StocktakeLine[]
  requestLines     PurchaseRequestLine[]
  orderLines       PurchaseOrderLine[]
  quoteLines       SupplierQuoteLine[]

  @@index([itemType])
  @@index([status])
}

model ItemUnitConversion {
  id                String   @id @default(uuid())
  itemId            String
  unitCode          String
  unitName          String?
  conversionRate    Float
  isDefaultPurchase Boolean  @default(false)
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, unitCode])
  @@index([unitCode])
  @@index([isDefaultPurchase])
}

model StocktakeSession {
  id            String    @id @default(uuid())
  code          String    @unique
  stocktakeDate DateTime  @default(now())
  branchCode    String
  warehouseCode String
  status        String    @default("DRAFT")
  approvedBy    String?
  approvedAt    DateTime?
  note          String?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lines StocktakeLine[]

  @@index([branchCode])
  @@index([warehouseCode])
  @@index([status])
  @@index([stocktakeDate])
}

model StocktakeLine {
  id               String  @id @default(uuid())
  stocktakeId      String
  itemId           String
  systemQuantity   Float
  actualQuantity   Float
  varianceQuantity Float
  reason           String?

  stocktake StocktakeSession @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  item      InventoryItem    @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([stocktakeId])
  @@index([itemId])
}

model InventoryBalance {
  id            String   @id @default(uuid())
  itemId        String
  warehouseCode String
  quantity      Float    @default(0)
  averageCost   Float    @default(0)
  updatedAt     DateTime @updatedAt

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, warehouseCode])
  @@index([warehouseCode])
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  importBatchId   String?
  code            String   @unique
  transactionType String
  transactionDate DateTime @default(now())
  branchCode      String
  warehouseCode   String
  toWarehouseCode String?
  referenceType   String?
  referenceId     String?
  referenceCode   String?
  status          String   @default("POSTED")
  note            String?
  createdBy       String?
  createdAt       DateTime @default(now())

  importBatch ImportBatch?               @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  lines       InventoryTransactionLine[]

  @@index([transactionType])
  @@index([transactionDate])
  @@index([warehouseCode])
  @@index([toWarehouseCode])
  @@index([importBatchId])
}

model InventoryTransactionLine {
  id             String  @id @default(uuid())
  transactionId  String
  itemId         String
  quantity       Float
  unitCost       Float
  totalCost      Float
  inputQuantity  Float?
  inputUnitCode  String?
  conversionRate Float   @default(1)
  inputUnitCost  Float?

  transaction InventoryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  item        InventoryItem        @relation(fields: [itemId], references: [id])

  @@index([transactionId])
  @@index([itemId])
}

model PurchaseRequest {
  id             String    @id @default(uuid())
  code           String    @unique
  requestDate    DateTime  @default(now())
  branchCode     String
  departmentCode String?
  requestedBy    String
  neededDate     DateTime?
  reason         String
  status         String    @default("DRAFT")
  approvedBy     String?
  approvedAt     DateTime?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lines  PurchaseRequestLine[]
  quotes SupplierQuote[]
  orders PurchaseOrder[]

  @@index([status])
  @@index([branchCode])
  @@index([departmentCode])
}

model PurchaseRequestLine {
  id                String  @id @default(uuid())
  requestId         String
  itemId            String
  quantity          Float
  estimatedUnitCost Float   @default(0)
  imageUrl          String?
  note              String?

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  item    InventoryItem   @relation(fields: [itemId], references: [id])

  @@index([requestId])
  @@index([itemId])
}

model SupplierQuote {
  id            String   @id @default(uuid())
  requestId     String
  supplierCode  String
  supplierName  String
  quotationDate DateTime @default(now())
  deliveryDays  Int?
  paymentTerms  String?
  totalAmount   Float    @default(0)
  isSelected    Boolean  @default(false)
  note          String?
  createdAt     DateTime @default(now())

  request PurchaseRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  lines   SupplierQuoteLine[]

  @@unique([requestId, supplierCode])
  @@index([requestId])
}

model SupplierQuoteLine {
  id        String @id @default(uuid())
  quoteId   String
  itemId    String
  quantity  Float
  unitCost  Float
  totalCost Float

  quote SupplierQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  item  InventoryItem @relation(fields: [itemId], references: [id])

  @@index([quoteId])
}

model PurchaseOrder {
  id             String    @id @default(uuid())
  code           String    @unique
  requestId      String?
  orderDate      DateTime  @default(now())
  expectedDate   DateTime?
  supplierCode   String
  supplierName   String
  branchCode     String
  departmentCode String?
  warehouseCode  String
  status         String    @default("DRAFT")
  totalAmount    Float     @default(0)
  approvedBy     String?
  approvedAt     DateTime?
  note           String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  request PurchaseRequest?    @relation(fields: [requestId], references: [id])
  lines   PurchaseOrderLine[]
  payable SupplierPayable?

  @@index([status])
  @@index([supplierCode])
  @@index([requestId])
  @@index([departmentCode])
}

model PurchaseOrderLine {
  id               String  @id @default(uuid())
  orderId          String
  itemId           String
  orderedQuantity  Float
  receivedQuantity Float   @default(0)
  unitCost         Float
  totalCost        Float
  imageUrl         String?

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  InventoryItem @relation(fields: [itemId], references: [id])

  @@index([orderId])
}

model SupplierPayable {
  id                String   @id @default(uuid())
  purchaseOrderId   String   @unique
  supplierCode      String
  supplierName      String
  recognizedDate    DateTime @default(now())
  originalAmount    Float
  outstandingAmount Float
  status            String   @default("OPEN")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([supplierCode])
  @@index([status])
}

model Recipe {
  id            String   @id @default(uuid())
  code          String   @unique
  productCode   String
  productName   String
  unit          String
  sellingPrice  Float    @default(0)
  version       Int      @default(1)
  effectiveFrom DateTime @default(now())
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines RecipeLine[]

  @@index([productCode])
  @@index([status])
}

model RecipeLine {
  id        String @id @default(uuid())
  recipeId  String
  itemId    String
  quantity  Float
  wasteRate Float  @default(0)

  recipe Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   InventoryItem @relation(fields: [itemId], references: [id])

  @@index([recipeId])
}

model AssetDepreciation {
  id                      String   @id @default(uuid())
  assetId                 String
  period                  String
  depreciationAmount      Float
  accumulatedDepreciation Float
  remainingValue          Float
  status                  String   @default("POSTED")
  runBy                   String?
  createdAt               DateTime @default(now())

  asset AssetRecord @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, period])
  @@index([period])
}

model AssetMaintenance {
  id                 String    @id @default(uuid())
  assetId            String
  maintenanceType    String
  scheduledDate      DateTime
  completedDate      DateTime?
  supplierName       String?
  cost               Float     @default(0)
  recurrenceRule     String?
  recurrenceInterval Int?      @default(1)
  recurrenceEndDate  DateTime?
  linkedWorkItemId   String?
  status             String    @default("SCHEDULED")
  note               String?
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  asset AssetRecord @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([scheduledDate])
  @@index([linkedWorkItemId])
  @@index([status])
}

model AssetDamageReport {
  id               String    @id @default(uuid())
  code             String    @unique
  assetId          String
  reportedDate     DateTime  @default(now())
  severity         String
  description      String
  status           String    @default("NEW")
  repairCost       Float     @default(0)
  repairTreatment  String?
  resolvedAt       DateTime?
  linkedWorkItemId String?
  reportedBy       String?
  resolvedBy       String?
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  asset AssetRecord @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reportedDate])
  @@index([linkedWorkItemId])
}

model CashbookAdjustment {
  id              String   @id @default(uuid())
  code            String   @unique
  entryDate       DateTime @default(now())
  entryType       String
  branchCode      String
  moneySourceCode String
  amount          Float
  description     String
  createdBy       String?
  createdAt       DateTime @default(now())

  @@index([entryDate])
  @@index([moneySourceCode])
}

model MoneyTransfer {
  id                  String   @id @default(uuid())
  importBatchId       String?
  code                String   @unique
  transferDate        DateTime
  branchCode          String
  fromMoneySourceCode String
  toMoneySourceCode   String
  amount              Float
  externalRef         String?
  description         String
  status              String   @default("PENDING_REVIEW")
  createdBy           String?
  approvedBy          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([transferDate])
  @@index([branchCode])
  @@index([status])
  @@index([importBatchId])
  @@index([branchCode, externalRef])
}

model Accrual {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  branchCode      String
  categoryCode    String
  totalAmount     Float
  startPeriod     String
  numberOfPeriods Int
  actualAmount    Float?
  sourceType      String?
  sourceId        String?
  status          String   @default("ACTIVE")
  note            String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedules AccrualSchedule[]

  @@index([status])
  @@index([startPeriod])
  @@index([sourceType, sourceId])
}

model AccrualSchedule {
  id        String    @id @default(uuid())
  accrualId String
  period    String
  amount    Float
  status    String    @default("PLANNED")
  postedAt  DateTime?

  accrual Accrual @relation(fields: [accrualId], references: [id], onDelete: Cascade)

  @@unique([accrualId, period])
  @@index([period])
}

model AccountingPeriod {
  id         String    @id @default(uuid())
  period     String
  branchCode String
  status     String    @default("OPEN")
  closedBy   String?
  closedAt   DateTime?
  reopenedBy String?
  reopenedAt DateTime?
  reason     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([period, branchCode])
  @@index([status])
}

model AuditLog {
  id           String   @id @default(uuid())
  occurredAt   DateTime @default(now())
  actorId      String?
  actorName    String?
  actorRole    String?
  branchCode   String?
  module       String
  action       String
  entityType   String
  entityId     String?
  entityCode   String?
  status       String   @default("SUCCESS")
  message      String?
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([occurredAt])
  @@index([actorId])
  @@index([actorRole])
  @@index([branchCode])
  @@index([module])
  @@index([entityType, entityId])
}

model AccountingAccount {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  accountType   String
  normalBalance String
  reportGroup   String
  parentCode    String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines JournalLine[]

  @@index([accountType])
  @@index([reportGroup])
}

model JournalEntry {
  id          String   @id @default(uuid())
  code        String   @unique
  entryDate   DateTime
  period      String
  branchCode  String
  sourceType  String
  sourceId    String
  sourceCode  String?
  description String
  status      String   @default("POSTED")
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalLine[]

  @@unique([sourceType, sourceId])
  @@index([period])
  @@index([branchCode])
  @@index([status])
}

model JournalLine {
  id             String  @id @default(uuid())
  entryId        String
  accountId      String
  debit          Float   @default(0)
  credit         Float   @default(0)
  departmentCode String?
  partnerCode    String?
  categoryCode   String?
  description    String?

  entry   JournalEntry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account AccountingAccount @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@index([departmentCode])
}

model PostingRule {
  id                String   @id @default(uuid())
  sourceType        String
  ruleCode          String   @unique
  name              String
  debitAccountCode  String
  creditAccountCode String
  conditionJson     String?
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([sourceType])
  @@index([status])
}

model PayrollImportRow {
  id              String   @id @default(uuid())
  importBatchId   String
  period          String
  employeeCode    String
  employeeName    String
  branchCode      String
  departmentCode  String
  baseSalary      Float
  allowanceAmount Float    @default(0)
  bonusAmount     Float    @default(0)
  insuranceAmount Float    @default(0)
  taxAmount       Float    @default(0)
  deductionAmount Float    @default(0)
  netAmount       Float
  externalRef     String?
  createdAt       DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([period, employeeCode, branchCode])
  @@index([period])
  @@index([branchCode])
  @@index([departmentCode])
}

model WorkItem {
  id             String    @id @default(uuid())
  code           String    @unique
  title          String
  description    String?
  branchCode     String
  departmentCode String
  assigneeId     String?
  assigneeName   String
  linkedModule   String?
  linkedId       String?
  linkedCode     String?
  checklistJson  String?
  attachmentUrl  String?
  period         String?
  priority       String    @default("MEDIUM")
  status         String    @default("TODO")
  dueDate        DateTime
  completedAt    DateTime?
  approvedBy     String?
  approvedAt     DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  histories      WorkItemHistory[]
  checklistItems WorkChecklistItem[]
  comments       WorkComment[]
  attachments    WorkAttachment[]

  @@index([branchCode])
  @@index([departmentCode])
  @@index([linkedModule, linkedId])
  @@index([status])
  @@index([dueDate])
}

model WorkItemHistory {
  id         String   @id @default(uuid())
  workItemId String
  action     String
  fromStatus String?
  toStatus   String?
  note       String?
  actor      String?
  createdAt  DateTime @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
}

model WorkChecklistItem {
  id          String    @id @default(uuid())
  workItemId  String
  title       String
  position    Int       @default(0)
  isDone      Boolean   @default(false)
  completedBy String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId, position])
  @@index([isDone])
}

model WorkComment {
  id         String   @id @default(uuid())
  workItemId String
  content    String
  authorId   String?
  authorName String
  authorRole String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId, createdAt])
}

model WorkAttachment {
  id         String   @id @default(uuid())
  workItemId String
  fileName   String
  mimeType   String?
  fileSize   Int?
  url        String
  uploadedBy String?
  createdAt  DateTime @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId, createdAt])
}

model ForecastAssumption {
  id             String   @id @default(uuid())
  period         String
  branchCode     String
  scenario       String
  assumptionType String
  amount         Float
  note           String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([period, branchCode, scenario, assumptionType])
  @@index([period])
  @@index([scenario])
}

model ReportTarget {
  id          String   @id @default(uuid())
  period      String
  branchCode  String
  metric      String
  targetValue Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([period, branchCode, metric])
  @@index([period])
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  actions   String[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  password       String
  name           String
  roleId         String
  role           Role               @relation(fields: [roleId], references: [id])
  branchAccesses UserBranchAccess[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([roleId])
}

model UserBranchAccess {
  id         String @id @default(uuid())
  userId     String
  branchCode String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchCode])
  @@index([userId])
}
